{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/twenty-docker/twenty/Dockerfile",
    "dockerBuildTarget": "twenty"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node packages/twenty-server/dist/database/scripts/setup-db.js && node packages/twenty-server/dist/command/command run-instance-commands && node packages/twenty-server/dist/main",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300
  }
}
